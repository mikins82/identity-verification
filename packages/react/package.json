{
  "name": "@identity-verification/react",
  "version": "0.1.0",
  "description": "React components for identity verification — selfie capture, phone input, address form, and more",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/identity-verification/sdk.git",
    "directory": "packages/react"
  },
  "keywords": ["identity", "verification", "kyc", "react", "components"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/react.css"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@identity-verification/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4",
    "jsdom": "^26",
    "react": "^19",
    "react-dom": "^19",
    "vite": "^6",
    "vite-plugin-dts": "^4",
    "vitest": "^3"
  }
}
