{
  "name": "@identity-verification/headless",
  "version": "0.1.0",
  "description": "Headless identity verification SDK — state machines, adapters, and theme definitions",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/identity-verification/sdk.git",
    "directory": "packages/headless"
  },
  "keywords": [
    "identity",
    "verification",
    "kyc",
    "headless"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@identity-verification/core": "workspace:*"
  },
  "devDependencies": {
    "jsdom": "^26.1.0",
    "tsup": "^8",
    "vitest": "^3"
  }
}
