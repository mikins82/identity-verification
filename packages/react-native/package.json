{
  "name": "@identity-verification/react-native",
  "version": "0.1.0",
  "description": "React Native components for identity verification — selfie capture, phone input, address form, and verification flow",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/identity-verification/sdk.git",
    "directory": "packages/react-native"
  },
  "keywords": [
    "identity",
    "verification",
    "kyc",
    "react-native",
    "components"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "react-native-vision-camera": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react-native-vision-camera": {
      "optional": true
    }
  },
  "dependencies": {
    "@identity-verification/core": "workspace:*",
    "@identity-verification/headless": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "tsup": "^8",
    "typescript": "^5.7"
  }
}
